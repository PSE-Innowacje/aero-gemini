COMPOSE_PROJECT_NAME=aero_dev

# Backend settings (aero.core.config uses AERO_ prefix)
AERO_APP_NAME=Aero Backend
AERO_JWT_SECRET=dev-secret-change-me
AERO_JWT_ALGORITHM=HS256
AERO_ACCESS_TOKEN_EXPIRE_MINUTES=60
AERO_DATABASE_URL=sqlite:////workspace/backend/aero.db
# Seed profile used by backend/seed.py: minimal | full (default: full)
SEED_PROFILE=full

# Frontend runtime config
VITE_API_BASE_URL=http://localhost:8000/api

# --- Production (infra/docker-compose.prod.yml) ---
# Copy this file to infra/.env on the server. Steps: infra/DEPLOY.local.md.example
# (your own infra/DEPLOY.local.md is listed in .gitignore).
# Run compose with `-p aero-prod` (see DEPLOY), or set COMPOSE_PROJECT_NAME=aero_prod on the VPS.
#
# Defaults: frontend on 127.0.0.1:8080, backend on 127.0.0.1:8000 — edge nginx+certbot (separate repo) proxies from the internet.
#
# Example SQLite in prod container (volume backend_data -> /app/data):
# AERO_DATABASE_URL=sqlite:////app/data/aero.db
# File logs (JSONL) default to <SQLite directory>/logs -> /app/data/logs; override if needed:
# AERO_LOG_DIR=/app/data/logs
# AERO_JWT_SECRET=<strong-random-secret>
# Hide /docs, /redoc, and /openapi.json (recommended on the public internet):
# AERO_EXPOSE_OPENAPI=false
#
# With nginx and API under /api (same-origin) you usually do not need to change CORS.
#
# The web image builds the frontend with VITE_API_BASE_URL=/api (same-origin via edge nginx).
